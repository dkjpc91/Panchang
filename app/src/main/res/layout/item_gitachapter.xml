<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_margin="2dp"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
      android:background="  #F69F84"
        android:backgroundTint="#F69F84"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="10dp"
        app:cardElevation="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <RelativeLayout
            android:layout_margin="1dp"

            android:background="@drawable/gitachapterbackground"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            >

            <TextView
                android:id="@+id/chaptername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="१. अर्जुन विषाद योग"
                android:textSize="22sp"
                android:textColor="#3F51B5"
                android:textStyle="bold"
                android:layout_alignParentStart="true"
                android:layout_marginTop="8dp" />

            <TextView
                android:textColor="#3F51B5"
                android:id="@+id/shlokaCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="४७ श्लोक"
                android:textSize="18sp"
                android:textStyle="bold"
                android:elevation="2dp"
                android:padding="4dp"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="8dp" />

            <TextView
                android:textColor="#3F51B5"
                android:id="@+id/chapterdesc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="अर्जुन की मानसिक स्थिति और उनके द्वारा युद्ध न करने के कारणों का वर्णन।"
                android:textSize="18sp"
                android:layout_below="@id/chaptername"
                android:layout_marginTop="4dp" />

        </RelativeLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>