<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="6dp"
        app:cardCornerRadius="18dp"
        app:cardElevation="4dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/grid_bg"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/ChapterName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="8dp"
                android:text="अध्याय 1: अर्जुन का विषाद योग"
                android:textColor="#800000"
                android:textSize="18sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chapterdescription"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp"
                android:text="अर्जुन युद्धभूमि पर अपने परिवार के सदस्यों और गुरुओं को देखकर संदेह और नैतिक संदेह में डूब जाता है।"
                android:textSize="16sp" />

            <TextView
                android:id="@+id/chapternumber"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingTop="8dp"
                android:text="अध्याय 1 पढ़ें"
                android:textColor="@android:color/holo_blue_dark"
                android:textStyle="bold" /> <!-- Added padding to the link -->
        </LinearLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>