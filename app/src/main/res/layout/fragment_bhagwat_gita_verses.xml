<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_gravity="center_horizontal"
    android:layout_width="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_height="match_parent"
    tools:context=".UI.Fragments.BhagwatGitaVersesFragment">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="-90dp"
        android:src="@drawable/header"/>
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:layout_marginTop="-130dp"
        android:padding="27dp"
        android:src="@drawable/splashtxt"/>


    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/borderred"
        android:layout_margin="1dp"
        android:orientation="vertical">

        <com.denzcoskun.imageslider.ImageSlider
            android:layout_marginTop="4dp"
            android:id="@+id/imageSliderBhagwatgita"
            android:layout_width="match_parent"
            android:layout_height="250dp"
            android:padding="0dp"
            app:iss_auto_cycle="true"
            app:iss_delay="3000"
            app:iss_no_dots="true"
            app:iss_period="3000"
            app:iss_placeholder="@drawable/om"
            app:iss_text_align="CENTER"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <androidx.recyclerview.widget.RecyclerView
            android:layout_gravity="center_horizontal"
            android:id="@+id/BhagwatgitaVerseRecycler"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            android:layout_width="match_parent"
            tools:listitem="@layout/bhagwatgitaverseitem"
            android:layout_height="match_parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/imageSliderBhagwatgita" />



    </LinearLayout>


</LinearLayout>