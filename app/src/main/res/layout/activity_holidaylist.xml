<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:lottie="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    tools:context=".UI.View.HolidayListActivity">


    <ImageView
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_marginTop="-90dp"
        android:src="@drawable/header"/>
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="130dp"
        android:layout_marginTop="-130dp"
        android:padding="27dp"
        android:src="@drawable/splashtxt"/>

    <TextView
        android:id="@+id/monthname"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="त्यौहार"
        android:textSize="36sp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:gravity="center"
        android:textColor="#F44336"/>
   <com.airbnb.lottie.LottieAnimationView
       android:id="@+id/lottieAnimationView"
       android:layout_gravity="center"
       android:layout_width="200dp"
       android:layout_height="200dp"
       app:lottie_loop="true"
       app:lottie_autoPlay="true"
       android:layout_centerInParent="true"
       app:lottie_rawRes="@raw/download"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/holidayrecycler"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="16dp" />




</LinearLayout>